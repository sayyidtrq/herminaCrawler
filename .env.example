APP_ENV=local
APP_NAME=Voice of Customer Crawler System
LOG_LEVEL=INFO
EXPORT_DIR=exports

# Required. Point this deployment at its own Postgres/Supabase database.
# Never reuse production credentials in local/dev/staging.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/voc_crawler

# Required for JWT-based user endpoints such as /api/auth/login.
# Generate a long random value per environment.
# Example: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET_KEY=change-me-to-a-long-random-value

# HMAC pepper for opaque VOC service tokens. Keep separate from the database.
# Generate a unique value per environment; never send it to OneBox.
SERVICE_TOKEN_PEPPER=change-me-to-another-long-random-value

# Required outside local dev. Signs opaque integration pagination cursors.
# Never share this value with OneBox; OneBox only stores the cursor string.
# Example: python -c "import secrets; print(secrets.token_urlsafe(48))"
INTEGRATION_CURSOR_SECRET=change-me-per-environment

# Browser CORS allowlist only. Backend-to-backend pull from OneBox does not need
# CORS, but direct browser calls from OneBox FE do.
# Use origins only: scheme + host + optional port. Do not include URL paths.
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Review source mode:
# - mock: fixture/mock data, safest for local smoke test
# - google_places: official Google Places source; review count may be limited
# - google_business_profile: official GBP source when client owns location access
# - third_party: external provider adapter
# - selenium: browser scraping workflow; operationally fragile, use carefully
REVIEW_SOURCE_MODE=mock

# Google source configuration.
GOOGLE_MAPS_API_KEY=
GOOGLE_PLACES_LANGUAGE_CODE=id
GOOGLE_PLACES_REGION_CODE=ID

# AI analysis provider. LOCAL_LLM_BASE_URL must be reachable from this process
# or from inside the Docker container. Avoid relying on a laptop-only LAN IP.
LOCAL_LLM_BASE_URL=http://192.168.1.115:11434/v1/
LOCAL_LLM_API_KEY=ollama
LOCAL_LLM_MODEL=qwen2.5:7b

# Fetch and retry behavior.
FETCH_LIMIT_PER_LOCATION=50
FETCH_TIMEOUT_SECONDS=30
FETCH_MAX_RETRY=3

# Selenium is not recommended as the primary production source. If used, keep it
# as a controlled worker flow, not a browser launched from request/response API.
SELENIUM_HEADLESS=false
SELENIUM_DEFAULT_TARGET_REVIEWS=100
SELENIUM_MAX_TARGET_REVIEWS=300
SELENIUM_SCROLL_DELAY_SECONDS=2
SELENIUM_MAX_SCROLL_ATTEMPTS=100
SELENIUM_WAIT_TIMEOUT_SECONDS=20
SELENIUM_USER_DATA_DIR=.selenium-profile

# Analysis and API pagination.
ANALYSIS_BATCH_SIZE=20
PROMPT_VERSION=v1
PAGE_SIZE=20

# Debug only. Keep false in shared/staging/production because raw payloads can
# contain user-generated content and external identifiers.
SHOW_RAW_PAYLOAD=false
