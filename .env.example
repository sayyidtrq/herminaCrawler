APP_ENV=local
APP_NAME=Hermina Review Intelligence
LOG_LEVEL=INFO
EXPORT_DIR=exports

# Required, no safe default. Must point at this deployment's actual
# Postgres/Supabase instance (never share a value across environments).
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/hermina_reviews

# Required, no safe default outside local dev. Generate a long random
# value per deployment — the code falls back to an insecure default if
# unset, which must never happen once this API is reachable externally.
JWT_SECRET_KEY=change-me-to-a-long-random-value

# Comma-separated list of origins allowed to call this API (e.g. add
# OneBox's origin here once known). Defaults to localhost:3000 if unset.
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Signs the opaque pagination cursors on /api/integration/v1/*. A caller who
# knows this value can forge a cursor pointing at another tenant's reviews, so
# it must be unique per environment and never shared with OneBox. Required
# whenever APP_ENV is not "local" — the app refuses to start without it.
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
INTEGRATION_CURSOR_SECRET=change-me-per-environment

REVIEW_SOURCE_MODE=mock
GOOGLE_MAPS_API_KEY=
GOOGLE_PLACES_LANGUAGE_CODE=id
GOOGLE_PLACES_REGION_CODE=ID

# LOCAL_LLM_BASE_URL is environment-specific. The code default points at
# a specific office LAN IP that will not resolve from another network or
# from inside a container — always set this explicitly per deployment.
LOCAL_LLM_BASE_URL=http://192.168.1.115:11434/v1/
LOCAL_LLM_API_KEY=ollama
LOCAL_LLM_MODEL=qwen2.5:7b
FETCH_LIMIT_PER_LOCATION=50
FETCH_TIMEOUT_SECONDS=30
FETCH_MAX_RETRY=3

SELENIUM_HEADLESS=false
SELENIUM_DEFAULT_TARGET_REVIEWS=100
SELENIUM_MAX_TARGET_REVIEWS=300
SELENIUM_SCROLL_DELAY_SECONDS=2
SELENIUM_MAX_SCROLL_ATTEMPTS=100
SELENIUM_WAIT_TIMEOUT_SECONDS=20
SELENIUM_USER_DATA_DIR=.selenium-profile

ANALYSIS_BATCH_SIZE=20
PROMPT_VERSION=v1

PAGE_SIZE=20
SHOW_RAW_PAYLOAD=false
